{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "poof",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "poof.k04.tech",
      "custom_domain": true
    }
  ],
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
